# ==========================================
# FallingDown AI — Environment configuration
# ==========================================

# Flask Server Config
FLASK_ENV=development # Change to 'production' in production environment
SECRET_KEY=change-this-to-a-secure-random-64-character-string
PORT=5000
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5173

# API Security
API_KEY=change-this-to-a-secure-random-api-key # Matches value used in pose_detector.py or requests headers

# MongoDB Connection Config
MONGO_URI=mongodb://localhost:27017/fallingdown

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Caregiver WhatsApp Recipients (Up to 5)
CAREGIVER_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX
CAREGIVER2_WHATSAPP_NUMBER=
CAREGIVER3_WHATSAPP_NUMBER=
CAREGIVER4_WHATSAPP_NUMBER=
CAREGIVER5_WHATSAPP_NUMBER=

# Google Gemini API key
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Public Server URL (For Twilio media links)
PUBLIC_URL=https://your-ngrok-or-production-domain.com

# File upload location
UPLOAD_FOLDER=uploads
